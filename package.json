{
  "name": "dotplane",
  "version": "0.1.18",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @dotplane/platform dev",
    "lint": "eslint packages --ext .ts,.tsx",
    "db:generate": "pnpm --filter @dotplane/platform db:generate",
    "db:migrate": "pnpm --filter @dotplane/platform db:migrate",
    "release:package": "bash scripts/package-release.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
